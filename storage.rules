rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSuperAdmin() {
      return signedIn()
        && (request.auth.token.super_admin == true
          || request.auth.token.superadmin == true
          || request.auth.token.superAdmin == true);
    }

    function staffPath(centerId, staffUid) {
      return /databases/(default)/documents/centers/$(centerId)/staff/$(staffUid);
    }

    function isStaff(centerId) {
      return signedIn()
        && exists(staffPath(centerId, uid()))
        && (
          get(staffPath(centerId, uid())).data.active == true
          || get(staffPath(centerId, uid())).data.activo == true
        );
    }

    function isCenterAdmin(centerId) {
      let staff = get(staffPath(centerId, uid())).data;
      let role = staff.accessRole != null ? staff.accessRole : staff.role;
      let r = role == null ? "" : role.lower();
      return isStaff(centerId) && (
        r == "center_admin"
        || r == "admin_centro"
        || r == "admin"
      );
    }

    match /centers-logos/{centerId}/{fileName} {
      allow read: if signedIn() && (isSuperAdmin() || isStaff(centerId));
      allow write: if signedIn() && (isSuperAdmin() || isCenterAdmin(centerId));
    }

    match /centers/{centerId}/posters/{allPaths=**} {
      allow read: if signedIn() && (isSuperAdmin() || isCenterAdmin(centerId));
      allow write: if false;
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
