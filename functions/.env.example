# ──────────────────────────────────────────────────────────────────────────────
# VARIABLES DE ENTORNO — Firebase Functions / Clave Salud Bot
# ──────────────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
#   1. Copia este archivo como ".env" en la misma carpeta (functions/.env)
#   2. Rellena cada valor con tus credenciales reales
#   3. NUNCA subas el .env a git (ya está en .gitignore)
#   4. En producción usa: firebase functions:secrets:set NOMBRE_VARIABLE
# ──────────────────────────────────────────────────────────────────────────────

# Token de la API de WhatsApp Business (Meta for Developers)
WHATSAPP_TOKEN=your_whatsapp_token_here

# ID del número de teléfono de WhatsApp Business
WHATSAPP_PHONE_ID=your_phone_id_here

# ID de la cuenta de WhatsApp Business
WHATSAPP_BUSINESS_ID=your_business_id_here

# API Key de Google Gemini (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Llave de cifrado AES-256 para Access Tokens de Meta (64 hex chars = 32 bytes)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# En producción, usar: firebase functions:secrets:set ENCRYPTION_KEY
ENCRYPTION_KEY=64_hex_chars_aqui
