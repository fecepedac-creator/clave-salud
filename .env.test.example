# ============================================================
# ClaveSalud — Variables de entorno para pruebas Playwright
# ============================================================
# Copia este archivo como .env.test (no comitear .env.test)
# Luego crea las cuentas de prueba en Firebase Authentication
# con los roles correspondientes en la colección centres/staff
# ============================================================

# URL del servidor de desarrollo
PLAYWRIGHT_BASE_URL=http://localhost:5175

# ID del centro de pruebas (ya existe en dev)
TEST_CENTER_ID=c_eji2qv61

# ---- Admin de Centro ----
ADMIN_EMAIL=admin.test@clavesalud.cl
ADMIN_PASSWORD=Test1234!

# ---- Doctor (Staff) ----
DOCTOR_EMAIL=doctor.test@clavesalud.cl
DOCTOR_PASSWORD=Test1234!

# Doctor ID en Firestore (staff doc id dentro del centro)
TEST_DOCTOR_ID=doctor_test_uid_001

# Mes a testear (formato YYYY-MM — ajustar al mes con datos en Firestore)
TEST_YEAR_MONTH=2026-03

# ---- Segundo doctor (para tests multi-tenant) ----
DOCTOR_B_EMAIL=doctor.b.test@clavesalud.cl
DOCTOR_B_PASSWORD=Test1234!
TEST_DOCTOR_B_ID=doctor_test_uid_002
