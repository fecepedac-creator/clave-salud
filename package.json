{
  "name": "ficha-clínica-electrónica--dr-felipe-cepeda",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:ci": "eslint App.tsx components/AdminDashboard.tsx components/InvitePage.tsx components/MigrationModal.tsx hooks/useAuth.ts hooks/useInvite.ts features/admin/components/ProfessionalManagement.tsx features/admin/components/WhatsappSettings.tsx features/admin/components/AdminAIUsageTab.tsx --ext .ts,.tsx --quiet",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:commercial": "node scripts/verify-commercial-readiness.mjs",
    "ops:verify": "node scripts/verify-ops.mjs",
    "test:rules": "firebase emulators:exec --only firestore \"vitest run --config vitest.rules.config.ts src/test/firestore-rules.test.ts\"",
    "test:e2e:pilot": "playwright test --project=pilot-simulated",
    "test:e2e:real-auth": "playwright test --project=pilot-real-auth",
    "test:e2e:invite": "playwright test --project=pilot-invite",
    "audit:run": "node scripts/audit/run-audit.cjs",
    "audit:setup:e2e": "node scripts/audit/run-audit.cjs --setup-playwright",
    "audit:superadmin": "node scripts/audit/run-audit.cjs --area superadmin",
    "audit:admin": "node scripts/audit/run-audit.cjs --area admin-center",
    "audit:doctor": "node scripts/audit/run-audit.cjs --area doctor-dashboard",
    "audit:whatsapp": "node scripts/audit/run-audit.cjs --area whatsapp-chatbot",
    "audit:all": "node scripts/audit/run-audit.cjs --all",
    "audit:all:smoke": "node scripts/audit/run-audit.cjs --all --profile smoke",
    "audit:all:deep": "node scripts/audit/run-audit.cjs --all --profile deep",
    "audit:all:strict": "node scripts/audit/run-audit.cjs --all --profile deep --require-playwright --enforce-clean",
    "vademecum:generate": "python scripts/generate_vademecum_registry.py",
    "identity:whatsapp": "node scripts/whatsapp-identity/run_identity_eval.cjs",
    "identity:whatsapp:agent": "npm --prefix functions run build && node scripts/whatsapp-identity/run_identity_eval.cjs --mode=agent"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.1",
    "googleapis": "^171.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.559.0",
    "mammoth": "^1.11.0",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-google-drive-picker": "^1.2.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.13",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^28.1.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
